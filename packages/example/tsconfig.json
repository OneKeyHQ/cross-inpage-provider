{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "strictNullChecks": false,
    "paths": {
      "components": ["./components"],
      "lib": ["./lib"],
      // bundler moduleResolution (needed for @mysten/sui 2.x exports) can't
      // resolve this deep path that lacks an exports entry; map it explicitly.
      "@benfen/bfc.js/dist/cjs/wallet-standard": [
        "./node_modules/@benfen/bfc.js/dist/esm/wallet-standard/index.d.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "chains/conflux/contract.js"
  ],
  "exclude": [
    "node_modules"
  ]
}